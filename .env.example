# Daisy Image Processor — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values for your environment.
#
#   cp .env.example .env
#
# For LocalStack (local development), source this file in your shell before
# running Terraform or the Lambda handler directly:
#
#   set -a && source .env && set +a
#
# These values are mirrored in terraform/local.tfvars for `make deploy-local`.
# ─────────────────────────────────────────────────────────────────────────────

# Required — S3 bucket that receives raw uploaded images.
# Must already exist or be created by Terraform before Lambda can process events.
SOURCE_BUCKET=source-images-bucket

# Required — S3 bucket that stores processed output images.
# MUST differ from SOURCE_BUCKET — writing processed images back to the source
# bucket would create an infinite S3→SQS→Lambda trigger loop.
PROCESSED_BUCKET=processed-images-bucket

# Required — SQS queue URL. The Lambda handler reads messages from this queue.
# LocalStack default follows the pattern: http://localhost:4566/000000000000/<queue-name>
SQS_QUEUE_URL=http://localhost:4566/000000000000/image-processing-queue

# Optional — Override AWS SDK endpoint. Set to LocalStack URL for local development.
# Leave blank or unset entirely when deploying to real AWS.
AWS_ENDPOINT_URL=http://localhost:4566

# Optional — AWS region. Defaults to us-east-1 if not set.
AWS_REGION=us-east-1
