# Terraform
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/*.lock.info
terraform/.terraform/
terraform/lambda.zip
terraform/.terraform.lock.hcl
# Local backend override — never commit (local dev only, contains no secrets)
terraform/backend_override.tf

# LocalStack
.localstack/

# Python
.venv/
**/__pycache__/
*.pyc
*.pyo
*.egg-info/

# Environment variable files (never commit populated .env)
.env

# Vendor (generated by `make vendor` — never commit)
vendor/

# Build scripts intermediate outputs
scripts/__pycache__/

# Chaos test fixtures (generated at runtime by make chaos)
tests/fixtures/chaos_*.jpg
tests/fixtures/chaos_*.bin
tests/fixtures/chaos_*.png

# IDE
.vscode/settings.json
